# Dependency directories
node_modules/
client/node_modules/
backend/node_modules/

# Environment variables (Sensitive Info)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
client/.env

# Build outputs
client/dist/
client/build/
backend/dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# OS Metadata
.DS_Store
Thumbs.db

# IDE / Editor folders
.vscode/
.idea/
*.swp
*.swo

# Database (if using local SQLite or similar)
backend/*.sqlite
backend/*.db